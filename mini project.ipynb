    "for n_neighbors in neighbors_settings:\n",
    "    # Build the model\n",
    "    clf = KNeighborsClassifier(n_neighbors=n_neighbors)\n",
    "    clf.fit(X_train, y_train)\n",
    "    \n",
    "    # Record training set accuracy\n",
    "    training_accuracy.append(clf.score(X_train, y_train))\n",
