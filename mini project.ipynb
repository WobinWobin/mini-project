    "def load_audio_files(directory):\n",
    "    audio_files = []\n",
    "    for filename in os.listdir(directory):\n",
    "        if filename.endswith(\".wav\"):\n",
    "            audio_files.append(os.path.join(directory, filename))\n",
    "    return audio_files"
