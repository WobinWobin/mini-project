'''Code for Feature Extraction using STFT'''

# Setting targets for the audio files
data_map = {
    "pd_dataset/HC_AH_noise_reduce/*.wav": 0,    # Healthy Control
    "pd_dataset/PD_AH_noise_reduce/*.wav": 1     # Parkinson's Disease
}

